# Copy this file to .env and fill in locally.
# Never commit .env.

OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=high

# Repository settings
GITHUB_REPO_OWNER=replace_me
GITHUB_REPO_NAME=embedded-cognition-model-selection

# Safety limits
MAX_AUTOFIX_ATTEMPTS=10
MAX_LOCAL_REPLICATIONS_WITHOUT_APPROVAL=25
EXPENSIVE_JOB_REPLICATION_THRESHOLD=250
EXPENSIVE_JOB_CORE_THRESHOLD=32
