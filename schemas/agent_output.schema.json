{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentOutput",
  "type": "object",
  "required": [
    "task_id",
    "status",
    "summary",
    "files_changed",
    "approval_needed",
    "next_actions"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "complete",
        "blocked",
        "failed",
        "needs_approval",
        "partial"
      ]
    },
    "summary": {
      "type": "string"
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_needed": {
      "type": "boolean"
    },
    "approval_request": {
      "type": "string"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}