{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blam3/Omitting-Context-in-Cognition/schemas/research_update.schema.json",
  "title": "OCECM Autonomous Research Update",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cycle_title",
    "track",
    "completed",
    "why_it_matters",
    "checks_run",
    "decision_needed",
    "next_bounded_task"
  ],
  "properties": {
    "cycle_title": {
      "type": "string",
      "minLength": 5
    },
    "track": {
      "type": "string",
      "enum": ["theorem", "simulation", "empirical", "manuscript", "governance", "infrastructure"]
    },
    "completed": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "why_it_matters": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "files_changed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "checks_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": {"type": "string"},
          "status": {"type": "string", "enum": ["pass", "fail", "not_run", "not_applicable"]},
          "notes": {"type": "string"}
        }
      }
    },
    "decision_needed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["needed", "question"],
      "properties": {
        "needed": {"type": "boolean"},
        "question": {"type": "string"},
        "options": {
          "type": "array",
          "items": {"type": "string"}
        },
        "default_if_no_response": {"type": "string"}
      }
    },
    "risks_or_uncertainties": {
      "type": "array",
      "items": {"type": "string"}
    },
    "next_bounded_task": {
      "type": "string",
      "minLength": 5
    }
  }
}
