{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskPacket",
  "type": "object",
  "required": [
    "task_id",
    "agent",
    "objective",
    "inputs",
    "expected_outputs",
    "approval_required"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "agent": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_required": {
      "type": "boolean"
    },
    "approval_reason": {
      "type": "string"
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}